# ─────────────────────────────────────────────
#  WedQuick Backend — Environment Variables
#  Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# App
NODE_ENV=production
PORT=3000
APP_URL=https://api.yourdomain.com

# ── MySQL (from cPanel → MySQL Databases) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpanelusername_wedquick
DB_USER=cpanelusername_wquser
DB_PASSWORD=YOUR_MYSQL_PASSWORD

# ── JWT ──
JWT_SECRET=REPLACE_WITH_64_CHAR_RANDOM_STRING
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_64_CHAR_STRING
JWT_REFRESH_EXPIRES_IN=30d

# ── MSG91 (OTP + SMS) ──
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_SENDER_ID=WEDQCK

# ── ZeptoMail (Transactional Email) ──
ZEPTO_TOKEN=
ZEPTO_FROM_EMAIL=orders@yourdomain.com
ZEPTO_FROM_NAME=WedQuick

# ── Razorpay ──
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── WhatsApp Business API ──
WABA_TOKEN=
WABA_PHONE_NUMBER_ID=

# ── AWS S3 (for product images) ──
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=wedquick-media

# ── Shadowfax Logistics ──
SHADOWFAX_CLIENT_CODE=
SHADOWFAX_TOKEN=
SHADOWFAX_BASE_URL=https://tracker.shadowfax.in/api
